# RevisionOS Environment Variables
# Copy this file to .env and fill in your values

# Required: Groq API key for AI features
GROQ_API_KEY=gsk_your_api_key_here
# Required: JWT signing secret for auth tokens (use 32+ random characters)
JWT_SECRET=replace_with_a_long_random_secret_value

# Optional: Override defaults
# DATABASE_URL=sqlite:///./revisionos.db
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://revisionos-frontend.pages.dev
# CORS_ORIGIN_REGEX=https://([A-Za-z0-9-]+\.)?revisionos-frontend\.pages\.dev
# LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# LLM_FALLBACK_MODEL=llama-3.1-8b-instant
# MAX_CONTEXT_TOKENS=800000
# UPLOAD_DIR=./uploads
# DAILY_NEW_CARDS_LIMIT=20
# CARDS_PER_DOCUMENT=20
# QUESTIONS_PER_DOCUMENT=10
# WEAKNESS_THRESHOLD=0.7
# DESIRED_RETENTION=0.9
